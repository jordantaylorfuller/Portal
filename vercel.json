{
  "redirects": [
    {
      "source": "/video.mp4",
      "destination": "https://github.com/jordantaylorfuller/Portal/releases/download/v1.0/video.mp4",
      "statusCode": 302
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
