{
  "outputDirectory": ".",
  "redirects": [
    {
      "source": "/video.mp4",
      "destination": "https://github.com/jordantaylorfuller/Portal/releases/download/v1.0/video.mp4",
      "statusCode": 302
    }
  ],
  "rewrites": [
    { "source": "/home", "destination": "/home/index.html" },
    { "source": "/works/:slug", "destination": "/works/:slug.html" },
    { "source": "/editors/:slug", "destination": "/editors/:slug.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/home/scrubber/frames/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/home/(css|js|images)/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "crons": [
    { "path": "/api/reels/sync-all", "schedule": "* * * * *" }
  ]
}
